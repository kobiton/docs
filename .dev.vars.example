# Copy this file to .dev.vars and fill in the values

# Cognito Configuration
COGNITO_DOMAIN=your-domain.auth.us-east-1.amazoncognito.com
COGNITO_CLIENT_ID=your-client-id
COGNITO_CLIENT_SECRET=your-client-secret
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx

# Session secret (generate with: openssl rand -hex 32)
SESSION_SECRET=your-64-char-hex-string

# ── RAG search ────────────────────────────────────────────────────────────────
# RAG is always deployed to EKS. The CF Worker proxies /api/query to FastAPI.
#
# Local dev: set RAG_API_URL to the local FastAPI running in Docker.
#   1. cd kobiton/.ai/rag-search && docker-compose up -d
#   2. Set RAG_API_URL below
#
# Production: set RAG_API_URL to the EKS ALB hostname in the CF dashboard.
#   Cloudflare dashboard → Pages → Settings → Environment variables

RAG_API_URL=http://localhost:8000

# Shared secret for FastAPI auth. Only needed when FastAPI is deployed with
# RAG_AUTH_ENABLED=true (EKS/cloud). Leave empty for local dev (auth is off by default).
# RAG_API_KEY=
