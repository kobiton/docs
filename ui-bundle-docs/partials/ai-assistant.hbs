{{! AI Assistant floating panel — injected once into body.hbs }}
<div id="ai-assistant" class="ai-assistant" aria-hidden="true" role="dialog" aria-label="Kobiton AI Assistant" aria-modal="true">
  <div class="ai-assistant__header">
    <div class="ai-assistant__header-info">
      <span class="ai-assistant__icon" aria-hidden="true">✦</span>
      <div>
        <div class="ai-assistant__title">Ask AI</div>
        <div class="ai-assistant__subtitle">Powered by Kobiton documentation</div>
      </div>
    </div>
    <button class="ai-assistant__close" id="ai-close-btn" aria-label="Close AI assistant">✕</button>
  </div>

  <div class="ai-assistant__body" id="ai-messages" role="log" aria-live="polite">
    <div class="ai-assistant__welcome">
      <p>Hi! Ask me anything about Kobiton — I'll answer from the documentation.</p>
    </div>
  </div>

  <div class="ai-assistant__footer">
    <div class="ai-assistant__input-row">
      <input
        id="ai-input"
        class="ai-assistant__input"
        type="text"
        placeholder="Ask a question…"
        autocomplete="off"
        aria-label="Ask a question"
        maxlength="300"
      />
      <button class="ai-assistant__send" id="ai-send-btn" aria-label="Send">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M16.5 1.5L8.25 9.75M16.5 1.5L11.25 16.5L8.25 9.75M16.5 1.5L1.5 6.75L8.25 9.75" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  </div>
</div>

{{! Floating launcher button — always visible }}
<button class="ai-launcher" id="ai-launcher-btn" aria-label="Open AI assistant" aria-expanded="false" aria-controls="ai-assistant">
  <svg class="ai-launcher__icon-open" width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <path d="M12 3C12 3 14.5 7 19 8C19 8 15 10 19 16C19 16 14 14 12 21C12 21 10 14 5 16C5 16 9 10 5 8C9.5 7 12 3 12 3Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
  </svg>
  <svg class="ai-launcher__icon-close" width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <path d="M18 6L6 18M6 6L18 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
  </svg>
  <span class="ai-launcher__label">Ask AI</span>
</button>
